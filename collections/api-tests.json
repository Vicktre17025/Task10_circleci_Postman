{
  "info": {
    "_postman_id": "a949c963-184e-4df1-8520-e7ab2e541b51",
    "name": "List (CI Fixed)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "item": [
    {
      "name": "GET Lists",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}"
          },
          {
            "key": "accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/folder/{{folder_id}}",
          "host": ["{{base_url}}"],
          "path": ["folder", "{{folder_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "",
              "if (jsonData.lists && jsonData.lists.length > 0) {",
              "    pm.collectionVariables.set('list_id', jsonData.lists[0].id);",
              "}",
              "",
              "jsonData.lists.forEach((list) => {",
              "    console.log(list.id);",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Create List",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}"
          },
          {
            "key": "accept",
            "value": "application/json"
          },
          {
            "key": "content-type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"test_list_{{randomInt}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/folder/{{folder_id}}/list",
          "host": ["{{base_url}}"],
          "path": ["folder", "{{folder_id}}", "list"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var body = pm.response.json();",
              "pm.collectionVariables.set('list_id', body.id);",
              "",
              "pm.test('Response has id', function () {",
              "    pm.expect(body.id).to.not.be.undefined;",
              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "GET List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}"
          },
          {
            "key": "accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/list/{{list_id}}",
          "host": ["{{base_url}}"],
          "path": ["list", "{{list_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var jsonData = pm.response.json();",
              "pm.test('Has space object', function () {",
              "    pm.expect(jsonData.space).to.exist;",
              "});"
            ]
          }
        }
      ]
    },

