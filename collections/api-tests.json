    {
      "name": "Create List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var body = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"list_id\", body.id);\r",
              "\r",
              "const Ajv = require('ajv');\r",
              "const ajv = new Ajv();\r",
              "\r",
              "var schema = {\r",
              "    \"type\": \"object\",\r",
              "    \"required\": [\r",
              "        \"id\",\r",
              "        \"name\",\r",
              "        \"deleted\",\r",
              "        \"orderindex\",\r",
              "        \"content\",\r",
              "        \"priority\",\r",
              "        \"assignee\",\r",
              "        \"task_count\",\r",
              "        \"due_date\",\r",
              "        \"start_date\",\r",
              "        \"folder\",\r",
              "        \"space\",\r",
              "        \"inbound_address\",\r",
              "        \"archived\",\r",
              "        \"override_statuses\",\r",
              "        \"statuses\",\r",
              "        \"permission_level\"\r",
              "    ],\r",
              "    \"properties\": {\r",
              "        \"id\": { \"type\": \"string\" },\r",
              "        \"name\": { \"type\": \"string\" },\r",
              "        \"deleted\": { \"type\": \"boolean\" },\r",
              "        \"orderindex\": { \"type\": \"integer\" },\r",
              "        \"content\": { \"type\": \"string\" },\r",
              "        \"priority\": { \"type\": [\"null\", \"object\", \"string\", \"number\"] },\r",
              "        \"assignee\": { \"type\": [\"null\", \"object\", \"string\"] },\r",
              "        \"task_count\": { \"type\": \"integer\" },\r",
              "        \"due_date\": { \"type\": [\"null\", \"string\"] },\r",
              "        \"start_date\": { \"type\": [\"null\", \"string\"] },\r",
              "        \"folder\": {\r",
              "            \"type\": \"object\",\r",
              "            \"required\": [\"id\", \"name\", \"hidden\", \"archived\", \"access\"],\r",
              "            \"properties\": {\r",
              "                \"id\": { \"type\": \"string\" },\r",
              "                \"name\": { \"type\": \"string\" },\r",
              "                \"hidden\": { \"type\": \"boolean\" },\r",
              "                \"archived\": { \"type\": \"boolean\" },\r",
              "                \"access\": { \"type\": \"boolean\" }\r",
              "            }\r",
              "        },\r",
              "        \"space\": {\r",
              "            \"type\": \"object\",\r",
              "            \"required\": [\"id\", \"name\", \"archived\", \"access\"],\r",
              "            \"properties\": {\r",
              "                \"id\": { \"type\": \"string\" },\r",
              "                \"name\": { \"type\": \"string\" },\r",
              "                \"archived\": { \"type\": \"boolean\" },\r",
              "                \"access\": { \"type\": \"boolean\" }\r",
              "            }\r",
              "        },\r",
              "        \"inbound_address\": { \"type\": \"string\" },\r",
              "        \"archived\": { \"type\": \"boolean\" },\r",
              "        \"override_statuses\": { \"type\": \"boolean\" },\r",
              "        \"statuses\": {\r",
              "            \"type\": \"array\",\r",
              "            \"items\": {\r",
              "                \"type\": \"object\",\r",
              "                \"required\": [\"id\", \"status\", \"orderindex\", \"color\", \"type\", \"status_group\"],\r",
              "                \"properties\": {\r",
              "                    \"id\": { \"type\": \"string\" },\r",
              "                    \"status\": { \"type\": \"string\" },\r",
              "                    \"orderindex\": { \"type\": \"integer\" },\r",
              "                    \"color\": { \"type\": \"string\" },\r",
              "                    \"type\": { \"type\": \"string\" },\r",
              "                    \"status_group\": { \"type\": \"string\" }\r",
              "                }\r",
              "            }\r",
              "        },\r",
              "        \"permission_level\": { \"type\": \"string\" }\r",
              "    }\r",
              "};\r",
              "\r",
              "const validate = ajv.compile(schema);\r",
              "const response = pm.response.json();\r",
              "\r",
              "\r",
              "pm.test(\"Schema is valid\", function () {\r",
              "   const valid = validate(response);\r",
              "   pm.expect(valid, JSON.stringify(validate.errors)).to.be.true;\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
