              "});"
            ]
          }
        }
      ]
    },

    {
      "name": "Delete List",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}"
          },
          {
            "key": "accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/list/{{list_id}}",
          "host": ["{{base_url}}"],
          "path": ["list", "{{list_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200 or 204', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});"
            ]
          }
        }
      ]
